# Copy to .env and fill values.
# This file is for LOCAL development (localhost URLs).
# For Docker Compose, see deploy/docker/.env.example

# --- SiliconFlow LLM (chat completions) ---
# Leave API key / model blank to use retrieval-only fallback locally.
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=

# --- Internal auth (shared secret across services) ---
# LOCAL DEV ONLY: allows gateway to start with demo defaults below.
# Do not enable this in production.
KB_ALLOW_INSECURE_DEFAULTS=true
KB_INTERNAL_TOKEN=dev-internal-token

# --- PostgreSQL ---
KB_DB_URL=jdbc:postgresql://localhost:5432/kb
KB_DB_NAME=kb
KB_DB_USER=kb
KB_DB_PASSWORD=kb

# --- Bootstrap admin (created on first startup if missing; dev defaults only) ---
KB_BOOTSTRAP_ADMIN_USER=admin
KB_BOOTSTRAP_ADMIN_PASSWORD=admin123

# --- Crypto (encrypts Provider API keys in DB; dev default only, change in production) ---
KB_CRYPTO_MASTER_KEY=dev-master-key-change-me

# --- Service URLs (localhost for local dev) ---
KB_EMBEDDER_URL=http://localhost:8090
KB_INDEX_URL=http://localhost:8082
KB_AI_URL=http://localhost:8083
KB_DOC_URL=http://localhost:8081
KB_GATEWAY_URL=http://localhost:8080

# --- Optional: OCR service ---
# KB_OCR_URL=http://localhost:8070

# --- Optional: external embedding API (for embeddingMode=api knowledge bases) ---
# KB_EMBED_API_BASE_URL=
# KB_EMBED_API_KEY=

# --- Optional: Eureka service discovery ---
# EUREKA_ENABLED=true
# EUREKA_SERVER_URL=http://localhost:8761
