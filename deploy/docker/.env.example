# Copy to .env before running docker compose.

# Optional SiliconFlow chat completions.
# Leave the key/model empty to run in degraded answer mode.
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=

# Shared service credentials.
# These are safe placeholders, not production values.
KB_ALLOW_INSECURE_DEFAULTS=false
KB_INTERNAL_TOKEN=change-me-internal-token

# Postgres
KB_DB_NAME=kb
KB_DB_USER=kb
KB_DB_PASSWORD=change-me-db-password

# Bootstrap admin
KB_BOOTSTRAP_ADMIN_USER=admin
KB_BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password

# Provider API key encryption
KB_CRYPTO_MASTER_KEY=change-me-crypto-master-key-32-bytes

# Internal service URLs
KB_EMBEDDER_URL=http://kb-embedder:8090
KB_INDEX_URL=http://kb-index-service:8082
KB_AI_URL=http://kb-ai-service:8083
KB_DOC_URL=http://kb-doc-service:8081

# Optional modules
KB_OCR_URL=
EUREKA_ENABLED=false
EUREKA_SERVER_URL=http://kb-eureka-server:8761
